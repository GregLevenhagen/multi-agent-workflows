# Azure AI Foundry Project
AZURE_AI_PROJECT_ENDPOINT=https://<your-project>.services.ai.azure.com/api
AZURE_AI_PROJECT_KEY=<your-project-key>
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Azure Content Safety
AZURE_CONTENT_SAFETY_ENDPOINT=https://<your-content-safety>.cognitiveservices.azure.com
AZURE_CONTENT_SAFETY_KEY=<your-content-safety-key>

# Data Directory (override for Docker; defaults to relative path from build output)
# DATA_DIRECTORY=/app/data

# Application Insights / OpenTelemetry
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=<your-key>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com
OTEL_CONSOLE_EXPORT=true
# OTEL_EXPORTER_OTLP_ENDPOINT defaults to http://localhost:4317 (gRPC) — override only if needed

# Environment
# DOTNET_ENVIRONMENT=development
