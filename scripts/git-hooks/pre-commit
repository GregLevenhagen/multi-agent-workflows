#!/usr/bin/env bash
# =============================================================================
# Pre-commit hook: all checks run before every commit
# - Prevents committing secrets/sensitive files
# - Runs dotnet format (lint) on staged C# files
# - Builds the solution
# - Runs automated tests
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo -e "${YELLOW}Running pre-commit checks...${NC}"

# ---------------------------------------------------------------------------
# 1. Check for secrets / sensitive files that should not be committed
# ---------------------------------------------------------------------------
SENSITIVE_PATTERNS=(
    "local.settings.json"
    "appsettings.Development.json"
    "secrets.json"
    ".env"
    "*.pfx"
    "*.key"
    "*.pem"
)

STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

for pattern in "${SENSITIVE_PATTERNS[@]}"; do
    # Use bash pattern matching for glob patterns
    while IFS= read -r file; do
        case "$file" in
            $pattern)
                echo -e "${RED}ERROR: Attempt to commit sensitive file: ${file}${NC}"
                echo "If this is intentional, use: git commit --no-verify"
                exit 1
                ;;
        esac
    done <<< "$STAGED_FILES"
done

# ---------------------------------------------------------------------------
# 2. Check for common secret patterns in staged file contents
# ---------------------------------------------------------------------------
if [ -n "$STAGED_FILES" ]; then
    SECRET_PATTERNS="(password|secret|api[_-]?key|access[_-]?token|private[_-]?key)\s*[:=]\s*[\"'][^\"']{8,}"

    for file in $STAGED_FILES; do
        if [ -f "$file" ]; then
            if git diff --cached -- "$file" | grep -iEq "$SECRET_PATTERNS"; then
                echo -e "${YELLOW}WARNING: Possible secret detected in ${file}${NC}"
                echo "Please review the staged changes in this file."
                echo "To proceed anyway, use: git commit --no-verify"
                exit 1
            fi
        fi
    done
fi

# ---------------------------------------------------------------------------
# 3. Run dotnet format (lint check) on staged C# files
# ---------------------------------------------------------------------------
STAGED_CS_FILES=$(echo "$STAGED_FILES" | grep '\.cs$' || true)

if [ -n "$STAGED_CS_FILES" ]; then
    # Find the solution or project file
    SLN_FILE=$(find . -maxdepth 2 -name "*.sln" -type f | head -1)
    CSPROJ_FILE=$(find . -maxdepth 3 -name "*.csproj" -type f | head -1)

    TARGET="${SLN_FILE:-$CSPROJ_FILE}"

    if [ -n "$TARGET" ]; then
        echo -e "${YELLOW}Running dotnet format check...${NC}"
        if ! dotnet format "$TARGET" --verify-no-changes --verbosity quiet 2>/dev/null; then
            echo -e "${RED}ERROR: Code formatting issues detected.${NC}"
            echo "Run 'dotnet format' to fix formatting, then re-stage your changes."
            exit 1
        fi
        echo -e "${GREEN}✓ Format check passed${NC}"
    else
        echo -e "${YELLOW}⚠ No .sln or .csproj found — skipping dotnet format${NC}"
    fi
else
    echo -e "${GREEN}✓ No C# files staged — skipping format check${NC}"
fi

# ---------------------------------------------------------------------------
# 4. Check for large files (> 5MB)
# ---------------------------------------------------------------------------
for file in $STAGED_FILES; do
    if [ -f "$file" ]; then
        FILE_SIZE=$(wc -c < "$file" | tr -d ' ')
        if [ "$FILE_SIZE" -gt 5242880 ]; then
            echo -e "${RED}ERROR: File ${file} is larger than 5MB (${FILE_SIZE} bytes)${NC}"
            echo "Consider using Git LFS or excluding this file."
            exit 1
        fi
    fi
done

# ---------------------------------------------------------------------------
# 5. Build the solution
# ---------------------------------------------------------------------------
SLN_FILE=$(find . -maxdepth 2 -name "*.sln" -type f | head -1)
CSPROJ_FILE=$(find . -maxdepth 3 -name "*.csproj" -type f | head -1)
BUILD_TARGET="${SLN_FILE:-$CSPROJ_FILE}"

if [ -n "$BUILD_TARGET" ]; then
    echo -e "${YELLOW}Building ${BUILD_TARGET}...${NC}"
    if ! dotnet build "$BUILD_TARGET" --verbosity quiet 2>&1; then
        echo -e "${RED}ERROR: Build failed. Fix build errors before committing.${NC}"
        exit 1
    fi
    echo -e "${GREEN}✓ Build succeeded${NC}"

    # -----------------------------------------------------------------------
    # 6. Run automated tests
    # -----------------------------------------------------------------------
    TEST_PROJECTS=$(find . -maxdepth 4 -name "*.csproj" -path "*[Tt]est*" -type f)

    if [ -n "$TEST_PROJECTS" ]; then
        echo -e "${YELLOW}Running tests...${NC}"
        if ! dotnet test "$BUILD_TARGET" --no-build --verbosity quiet 2>&1; then
            echo -e "${RED}ERROR: Tests failed. Fix failing tests before committing.${NC}"
            exit 1
        fi
        echo -e "${GREEN}✓ All tests passed${NC}"
    else
        echo -e "${YELLOW}⚠ No test projects found — skipping tests${NC}"
    fi
else
    echo -e "${YELLOW}⚠ No .sln or .csproj found — skipping build & test${NC}"
fi

echo -e "${GREEN}✓ All pre-commit checks passed${NC}"
