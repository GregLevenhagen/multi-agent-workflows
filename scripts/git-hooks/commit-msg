#!/usr/bin/env bash
# =============================================================================
# Commit-msg hook: validates commit message format
# - Enforces minimum length
# - Warns on missing conventional commit prefix
# =============================================================================
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(cat "$COMMIT_MSG_FILE")

# Strip comments and leading/trailing whitespace
CLEAN_MSG=$(echo "$COMMIT_MSG" | grep -v '^#' | sed -e 's/^[[:space:]]*//' -e 's/[[:space:]]*$//')
FIRST_LINE=$(echo "$CLEAN_MSG" | head -1)

# ---------------------------------------------------------------------------
# 1. Minimum length check
# ---------------------------------------------------------------------------
if [ ${#FIRST_LINE} -lt 10 ]; then
    echo -e "${RED}ERROR: Commit message too short (${#FIRST_LINE} chars). Minimum is 10.${NC}"
    echo "Write a meaningful commit message describing your changes."
    exit 1
fi

# ---------------------------------------------------------------------------
# 2. Max first-line length (soft warning)
# ---------------------------------------------------------------------------
if [ ${#FIRST_LINE} -gt 72 ]; then
    echo -e "${YELLOW}WARNING: First line is ${#FIRST_LINE} chars (recommended max: 72)${NC}"
fi

# ---------------------------------------------------------------------------
# 3. Conventional commit prefix (soft warning, not enforced)
# ---------------------------------------------------------------------------
CONVENTIONAL_PATTERN="^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\(.+\))?!?:"

if ! echo "$FIRST_LINE" | grep -qE "$CONVENTIONAL_PATTERN"; then
    echo -e "${YELLOW}TIP: Consider using conventional commit format:${NC}"
    echo "  feat: add new feature"
    echo "  fix: resolve bug"
    echo "  docs: update documentation"
    echo "  test: add/update tests"
    echo "  chore: maintenance tasks"
fi

echo -e "${GREEN}✓ Commit message check passed${NC}"
